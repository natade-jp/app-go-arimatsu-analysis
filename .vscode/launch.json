{
	"version": "0.2.0",
	"configurations": [
		{
			"type": "node",
			"request": "launch",
			"name": "npm run parse-images",
			"runtimeExecutable": "npm",
			"runtimeArgs": ["run", "parse-images"],
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal",
			"skipFiles": ["<node_internals>/**"]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "npm run inspect-image",
			"runtimeExecutable": "npm",
			"runtimeArgs": ["run", "inspect-image"],
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal",
			"skipFiles": ["<node_internals>/**"]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "npm run extract-column",
			"runtimeExecutable": "npm",
			"runtimeArgs": ["run", "extract-column"],
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal",
			"skipFiles": ["<node_internals>/**"]
		}
	]
}
