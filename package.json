{
	"name": "app-go-arimatsu-analysis",
	"version": "0.1.0",
	"description": "名鉄名古屋〜有松の乗換CSV生成ツール",
	"type": "module",
	"main": "src/index.js",
	"scripts": {
		"start": "node src/index.js",
		"parse-images": "node src/index.js data/images data/output.csv",
		"inspect-image": "node src/inspectImage.js",
		"extract-column": "node src/extractColumn.js",
		"concat-columns": "node src/concatColumns.js"
	},
	"keywords": [
		"meitetsu",
		"timetable",
		"csv",
		"pdf",
		"ocr"
	],
	"dependencies": {
		"csv-writer": "^1.6.0",
		"multilingual-purejs-ocr": "^1.0.1",
		"pdf-parse": "^1.1.1",
		"sharp": "^0.34.5"
	},
	"engines": {
		"node": ">=18"
	}
}
